---
import { AstroFont } from "astro-font";
import { SEO } from "astro-seo";
import Toaster from "../components/shadcn/ui/toast/Toaster.vue";

import Header from "./header.astro";
import Footer from "./footer.astro";
---

<script is:inline>
    const setTheme = () => {
        if (typeof window.localStorage.getItem("theme") === "string") {
            const currentTheme = window.localStorage.getItem("theme");
            if (currentTheme === "dark") {
                document.documentElement.classList.add("dark");
            }
        }
        if (
            typeof window.localStorage.getItem("theme") !== "string" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches
        ) {
            document.documentElement.classList.add("dark");
        }
    };

    setTheme();

    document.addEventListener("astro:after-swap", setTheme);
</script>

<html lang="en">
    <head>
        <SEO
            charset="utf-8"
            title="Avatio"
            description="アバターセットアップ共有サービス"
            openGraph={{
                basic: {
                    title: "Avatio",
                    type: "",
                    image: "",
                },
            }}
            twitter={{
                creator: "@liria_work",
                card: "summary",
                image: "",
                title: "Avatio",
                description: "アバターセットアップ共有サービス",
            }}
            extend={{
                link: [{ rel: "icon", href: "/favicon.ico" }],
                meta: [
                    {
                        name: "viewport",
                        content: "width=device-width, initial-scale=1",
                    },
                ],
            }}
        />
        <AstroFont
            config={[
                {
                    src: [],
                    name: "Montserrat",
                    // Google Fonts URL
                    googleFontsURL:
                        "https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap",
                    preload: true,
                    display: "swap",
                    selector: "body",
                    fallback: "sans-serif",
                },
            ]}
        />
    </head>

    <body class="bg-[#f0f0f0] dark:bg-[#262626] px-6 md:px-20 lg:px-40">
        <div class="w-full max-w-[1300px] flex flex-col mx-auto">
            <Header />
            <slot />
            <Footer />
        </div>
    </body><Toaster client:load />
</html>
